<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <div class="d-flex gap-2 align-items-center">
        <img src="/img/favicon.png" alt="E-commerce Logo" style="width: 48px;">
        <a class="navbar-brand" href="/">MyEcommerce</a>
    </div>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link fs-5" href="/products">Productos</a>
        </li>
        <li class="nav-item">
          <a class="nav-link fs-5" href="/realTimeProducts">RealTimeProducts</a>
        </li>
        <li class="nav-item">
          <a class="nav-link fs-5" href="/carts">Carritos</a>
        </li>
      </ul>

    <div>
      <button type="button" class="btn">
        <i class="bi bi-cart3 fs-4"></i>
      </button>

    </div>

  </div>
</nav>

<div class="d-flex justify-content-center align-items-center h-100">
  <div class="card mb-3" style="max-width: 1024px; width: 1024px;">
    <div class="row g-0">
      <div class="col-md-4">
        <div
          class="d-flex justify-content-center align-items-center bg-light h-100"
        >
          <img
            src={{lookup productData.thumbnails 0}}
            class="img-fluid product-image-detail"
            alt={{productData.title}}
          />
        </div>
      </div>
      <div class="col-md-8">
        <div class="card-body">
          <p class="m-0 product-category-detail">{{productData.category}}</p>
          <h5 class="card-title product-name-detail">{{productData.title}}</h5>
          <p
            class="card-text product-description-detail"
          >{{productData.description}}</p>
          <div class="d-flex justify-content-between w-100">
            <p class="card-text product-stock-detail m-0"><span
                class="fst-italic"
              >In stock: </span>{{productData.stock}}</p>
            <div
              class="product-status-detail d-flex justify-content-center align-items-center"
            >
              {{#if productData.status}}
                <span class="badge text-bg-success">Habilitado</span>
              {{else}}
                <span class="badge text-bg-danger">Deshabilitado</span>
              {{/if}}
            </div>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <p
              class="card-text product-price-detail text-success mt-3"
            >${{productData.price}}</p>
            <div class="d-flex gap-1 align-items-center">
              <label>Cantidad</label>
              <input
              name="quantity"
              id="productQuantity"
              type="number"
              value="1"
              min="1"
            />
            </div>
          </div>

          <form
            action=""
            class="mb-3 w-100 d-flex align-items-center justify-content-between gap-2"
          >
            <select name="" id="cartSelect">
              {{#each cartList}}
                <option value={{this._id}}>{{this._id}}</option>
              {{/each}}
            </select>

            <button class="btn btn-primary w-100" id="addToCartBtn">Agregar al
              carrito</button>
          </form>

        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/product.js"></script>