<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container-fluid">
    <div>
      <a class="navbar-brand" href="#">MyCommerce</a>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarSupportedContent"
        aria-controls="navbarSupportedContent"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
    </div>

    <form
      class="d-flex align-items-center mb-0 justify-item-center flex-grow-1"
      role="search"
      style="max-width: 75%;"
    >
      <div class="input-group">
        <div class="input-group-text">
          <i class="bi bi-search"></i>
        </div>
        <input
          class="form-control me-2"
          type="search"
          placeholder="Buscar producto"
          aria-label="Search"
        />
      </div>
      <button class="btn btn-outline-success" type="submit">Search</button>
    </form>

    <div>
      <button type="button" class="btn">
        <i class="bi bi-cart3 fs-4"></i>
      </button>

    </div>

  </div>
</nav>

<div class="d-flex justify-content-center align-items-center h-100">
  <div class="card mb-3" style="max-width: 1024px;">
    <div class="row g-0">
      <div class="col-md-4">
        <div
          class="d-flex justify-content-center align-items-center bg-light h-100"
        >
          <img
            src={{lookup this.thumbnails 0}}
            class="img-fluid product-image-detail"
            alt={{this.title}}
          />
        </div>
      </div>
      <div class="col-md-8">
        <div class="card-body">
          <p class="m-0 product-category-detail">{{this.category}}</p>
          <h5 class="card-title product-name-detail">{{this.title}}</h5>
          <p class="card-text product-description-detail">{{this.description}}</p>
          <div class="d-flex justify-content-between w-100">
            <p class="card-text product-stock-detail m-0"><span class="fst-italic">In stock: </span>{{this.stock}}</p>
            <div class="product-status-detail d-flex justify-content-center align-items-center">
                {{#if this.status}}
                <span class="badge text-bg-success">Habilitado</span>
                {{else}}
                <span class="badge text-bg-danger">Deshabilitado</span>
                {{/if}}
            </div>
          </div>
          <p class="card-text product-price-detail text-success mt-3">${{this.price}}</p>
          <div class="mb-3 w-100">
            <a href="#" class="btn btn-primary w-100">Agregar al carrito</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>