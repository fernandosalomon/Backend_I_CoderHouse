<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <title>E-commerce</title>
  </head>
  <body>

    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <div>
          <a class="navbar-brand" href="#">MyCommerce</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
        </div>

        <form
          class="d-flex align-items-center mb-0 justify-item-center flex-grow-1"
          role="search"
          style="max-width: 75%;"
        >
          <div class="input-group">
            <div class="input-group-text">
              <i class="bi bi-search"></i>
            </div>
            <input
              class="form-control me-2"
              type="search"
              placeholder="Buscar producto"
              aria-label="Search"
            />
          </div>
          <button class="btn btn-outline-success" type="submit">Search</button>
        </form>

        <div>

          <button type="button" class="btn" data-bs-toggle="modal" data-bs-target="#addNewProductModal">
            <i class="bi bi-plus-square-fill fs-2 text-primary"></i>
          </button>

          <button type="button" class="btn">
            <i class="bi bi-cart3 fs-4"></i>
          </button>

        </div>

      </div>
    </nav>

    <div style="min-height: calc(100vh - 145px);">
      {{{body}}}
    </div>

    <footer class="bg-light w-100 d-flex justify-content-center py-4">
      <p class="m-0">Created by Fernando F. Salomón - All Rights Reserved</p>
    </footer>

    <div
      class="modal fade"
      id="addNewProductModal"
      tabindex="-1"
      aria-labelledby="addNewProductModalLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Agregar nuevo producto</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">
            <form id="newProductForm">
              <div class="mb-3">
                <label for="title" class="form-label">Nombre del producto</label>
                <input
                  type="text"
                  class="form-control"
                  id="title"
                  name="title"
                  aria-describedby="title"
                  required
                />
                <p id="titleErrMsg" class="d-none"></p>
              </div>

              <div class="mb-3">
                <label for="description" class="form-label">Descripción del
                  producto</label>
                <input
                  type="text"
                  class="form-control"
                  id="description"
                  name="description"
                  aria-describedby="description"
                  required
                />
                <p id="descriptionErrMsg" class="d-none"></p>
              </div>

              <div class="row">
                <div class="mb-3 col">
                  <label for="code" class="form-label">Código del producto</label>
                  <input
                    type="text"
                    class="form-control"
                    id="code"
                    name="code"
                    aria-describedby="code"
                    placeholder="ej.: AA-588-2525"
                    required
                  />
                  <p id="codeErrMsg" class="d-none"></p>
                </div>

                <div class="mb-3 col">
                  <label for="price" class="form-label">Precio del producto</label>
                  <div class="input-group">
                    <div class="input-group-text">$</div>
                    <input
                      type="text"
                      class="form-control"
                      id="price"
                      name="price"
                      value=""
                      aria-describedby="price"
                      onblur="this.value = this.value != '' ? (/\.\d{2}/.test(this.value) ? this.value : /\.\d+/.test(this.value) ? this.value + '0' : this.value + '.00') : ''"
                      required
                    />
                  </div>
                </div>
                <p id="priceErrMsg" class="d-none"></p>
              </div>

              <div class="row d-flex align-items-center">

                <div class="mb-3 col-8">
                  <label for="stock" class="form-label">Stock del producto</label>
                  <input
                    type="number"
                    class="form-control"
                    id="stock"
                    name="stock"
                    aria-describedby="stock"
                    required
                  />
                  <p id="stockErrMsg" class="d-none"></p>
                </div>

                <div class="d-flex flex-column gap-3 col-3">
                  <div class="form-check d-flex">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="status"
                      id="statusFalse"
                      value="true"
                      checked
                    />
                    <label class="form-check-label ms-2" for="statusFalse">
                      Habilitado
                    </label>
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="status"
                      id="statusFalse"
                      value="false"
                    />
                    <label class="form-check-label" for="statusFalse">
                      Deshabilitado
                    </label>
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label for="category" class="form-label">Categoría del producto</label>
                <input
                  type="text"
                  class="form-control"
                  id="category"
                  name="category"
                  aria-describedby="category"
                  placeholder="ej.: Tecnología"
                  required
                />
                <p id="categoryErrMsg" class="d-none"></p>
              </div>

              <div class="mb-3">
                <label for="thumbnail" class="form-label">Imágen del producto</label>
                <input
                  type="text"
                  class="form-control"
                  id="thumbnails"
                  name="thumbnails"
                  aria-describedby="thumbnail"
                  placeholder="http://example.com/imagen.png"
                  required
                />
                <p id="thumbnailsErrMsg" class="d-none"></p>
              </div>

              <div class="w-100 d-flex justify-content-center">
                <button type="submit" class="btn btn-primary w-100 mt-1">Crear
                  producto</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>