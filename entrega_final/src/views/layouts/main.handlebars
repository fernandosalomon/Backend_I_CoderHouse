<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <title>E-commerce</title>
  </head>
  <body>

    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <div>
          <a class="navbar-brand" href="#">MyCommerce</a>
          <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
        </div>

        <form
          class="d-flex align-items-center mb-0 justify-item-center flex-grow-1"
          role="search"
          style="max-width: 75%;"
        >
          <div class="input-group">
            <div class="input-group-text">
              <i class="bi bi-search"></i>
            </div>
            <input
              class="form-control me-2"
              type="search"
              placeholder="Buscar producto"
              aria-label="Search"
            />
          </div>
          <button class="btn btn-outline-success" type="submit">Search</button>
        </form>

        <div>

          <button type="button" class="btn">
            <i class="bi bi-plus-square-fill fs-2 text-primary"></i>
          </button>

          <button type="button" class="btn">
            <i class="bi bi-cart3 fs-4"></i>
          </button>

        </div>

      </div>
    </nav>

    <div style="min-height: calc(100vh - 145px);">
      {{{body}}}
    </div>

    <footer class="bg-light w-100 d-flex justify-content-center py-4">
      <p class="m-0">Created by Fernando F. Salomón - All Rights Reserved</p>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
  </body>
</html>